APP_NAME=AIDetector API
# use production / staging / preview only in real deployments
ENVIRONMENT=development
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=AIDetector
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# RepreGuard detect microservice
# in production, point this to the real internal detect service instead of host.docker.internal
DETECT_SERVICE_URL=http://host.docker.internal:9000
DETECT_SERVICE_TIMEOUT=10
