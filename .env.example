APP_NAME=AIDetector API
# runtime template used by both local development and production
# admin credentials belong in .env.ops instead of this file
ENVIRONMENT=development
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=aidetector_app
POSTGRES_PASSWORD=replace-with-a-strong-runtime-password
POSTGRES_DB=AIDetector
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Detect service
# legacy base URL, still supported
DETECT_SERVICE_URL=https://umcat.cis.um.edu.mo
# preferred when the provider exposes a full detect endpoint such as aidetect.php
DETECT_SERVICE_DETECT_URL=https://umcat.cis.um.edu.mo/api/aidetect.php
# optional dedicated health endpoint; if omitted, /ready will probe DETECT_SERVICE_DETECT_URL directly
# DETECT_SERVICE_HEALTH_URL=https://umcat.cis.um.edu.mo/api/health.php
DETECT_SERVICE_TIMEOUT=10
